{
    "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
      "cacheVariables": {}
    },
    {
      "name": "SlotA-Debug",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "APP_SLOT": "A"
      }
    },
    {
      "name": "SlotA-Debug-Fault",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "APP_SLOT": "A",
        "APP_ROLLBACK_DEMO_FAULT": "ON"
      }
    },
    {
      "name": "SlotA-Release",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "APP_SLOT": "A"
      }
    },
    {
      "name": "SlotB-Debug",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "APP_SLOT": "B"
      }
    },
    {
      "name": "SlotB-Debug-Fault",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "APP_SLOT": "B",
        "APP_ROLLBACK_DEMO_FAULT": "ON"
      }
    },
    {
      "name": "SlotB-Release",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "APP_SLOT": "B"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "SlotA-Debug",
      "configurePreset": "SlotA-Debug"
    },
    {
      "name": "SlotA-Debug-Fault",
      "configurePreset": "SlotA-Debug-Fault"
    },
    {
      "name": "SlotA-Release",
      "configurePreset": "SlotA-Release"
    },
    {
      "name": "SlotB-Debug",
      "configurePreset": "SlotB-Debug"
    },
    {
      "name": "SlotB-Debug-Fault",
      "configurePreset": "SlotB-Debug-Fault"
    },
        {
            "name": "SlotB-Release",
            "configurePreset": "SlotB-Release"
        }
    ]
}
